ENVIRONMENT=development
PORT=4000
JWT_SECRET=replace-with-secure-secret-min-32-chars
OPENAI_API_KEY=replace-with-openai-key-in-deployment-secret-store
AI_PROVIDER=mock
AI_FALLBACK_PROVIDER=mock
AI_SAFETY_GUARD_ENABLED=true
AI_PROVIDER_TIMEOUT_MS=15000
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
ATTACHMENT_ANALYSIS_ENABLED=true
ATTACHMENT_MAX_BYTES=1048576
ATTACHMENT_TEXT_MAX_CHARS=8000
ATTACHMENT_ALLOWED_MIME_TYPES=text/plain,text/markdown,application/json
ATTACHMENT_ALLOW_PDF_TEXT=false
STT_PROVIDER=mock
STT_FALLBACK_PROVIDER=mock
STT_MAX_AUDIO_BYTES=5242880
STT_MAX_DURATION_SECONDS=30
STT_PROVIDER_TIMEOUT_MS=20000
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=
DATABASE_URL=file:backend/data/healthy-you.sqlite
CORS_ORIGIN=*
OPENAI_MODEL=gpt-4.1-mini
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_DEFAULT_MAX=120
RATE_LIMIT_AI_MAX=20
RATE_LIMIT_SYNC_MAX=60
RATE_LIMIT_EXPORT_DELETE_MAX=10
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_AUTH_WINDOW_MS=900000
REQUEST_BODY_LIMIT_JSON=1mb
REQUEST_BODY_LIMIT_AI_IMAGE=6mb
LOG_LEVEL=info
REQUEST_ID_HEADER=X-Request-Id
MONITORING_ENABLED=true
MONITORING_SAFE_STATUS_ENABLED=true
